{
  "settings": {
    "screenshot_dir": "./sign_screenshots",
    "report_dir": "./sign_reports",
    "headless": true,
    "timeout_seconds": 30,
    "interval_between_sites": 5
  },
  "sites": [
    {
      "name": "示例：论坛签到（账号密码）",
      "enabled": false,
      "login_type": "password",
      "login_url": "https://bbs.example.com/login",
      "checkin_url": "https://bbs.example.com/signin",
      "username": "${ENV:FORUM_USER}",
      "password": "${ENV:FORUM_PASS}",
      "username_selector": "#username",
      "password_selector": "#password",
      "submit_selector": "#login-btn",
      "checkin_selectors": [
        ".sign-btn",
        "#checkin",
        "button:has-text('签到')",
        "a:has-text('签到')"
      ],
      "success_keywords": ["签到成功", "已签到", "连续签到"],
      "already_signed_keywords": ["今日已签到", "已打卡"]
    },
    {
      "name": "示例：API Token 签到",
      "enabled": false,
      "login_type": "token",
      "checkin_url": "https://api.example.com/v1/user/checkin",
      "token": "${ENV:API_TOKEN}",
      "checkin_method": "POST",
      "checkin_headers": {
        "Authorization": "Bearer ${ENV:API_TOKEN}",
        "Content-Type": "application/json"
      },
      "checkin_body": "{}",
      "success_keywords": ["success", "ok"],
      "already_signed_keywords": ["already", "重复"]
    },
    {
      "name": "示例：有验证码的站点",
      "enabled": false,
      "login_type": "captcha",
      "login_url": "https://example.com/login",
      "checkin_url": "https://example.com/signin",
      "username": "${ENV:SITE_USER}",
      "password": "${ENV:SITE_PASS}",
      "checkin_selectors": [".qiandao", "#signBtn"],
      "success_keywords": ["签到成功"],
      "already_signed_keywords": ["已签"]
    },
    {
      "name": "示例：扫码登录",
      "enabled": false,
      "login_type": "qrcode",
      "login_url": "https://example.com/qrlogin",
      "checkin_url": "https://example.com/signin",
      "checkin_selectors": [".sign-btn"],
      "success_keywords": ["签到成功"],
      "qrcode_wait_seconds": 120
    }
  ]
}
